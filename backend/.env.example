# Mini Jira Backend - Environment Variables

# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mini_jira

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session
SESSION_SECRET=your-secret-key-min-32-characters-long

# Email Provider - Resend
RESEND_API_KEY=your-resend-api-key

# Email Provider - SMTP (fallback)
SMTP_HOST=smtp.empresa.com
SMTP_PORT=587
SMTP_USER=user@empresa.com
SMTP_PASS=password
SMTP_FROM=noreply@empresa.com

# Frontend
FRONTEND_URL=http://localhost:5173
